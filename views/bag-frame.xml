<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

  <!-- Main bag frame - matches CreateFrame("Frame", "EreaRpPlayerBagFrame", UIParent) from v1.3.0 -->
  <Frame name="EreaRpPlayerBagFrame" parent="UIParent" enableMouse="true" movable="true" hidden="true">
    <Size>
      <AbsDimension x="235" y="280"/>
    </Size>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground"
              edgeFile="Interface\DialogFrame\UI-DialogBox-Border"
              tile="true">
      <EdgeSize>
        <AbsValue val="32"/>
      </EdgeSize>
      <TileSize>
        <AbsValue val="32"/>
      </TileSize>
      <BackgroundInsets>
        <AbsInset left="11" right="12" top="12" bottom="11"/>
      </BackgroundInsets>
    </Backdrop>

    <Layers>
      <Layer level="OVERLAY">
        <!-- Title -->
        <FontString name="$parentTitle" inherits="GameFontNormal">
          <Anchors>
            <Anchor point="TOP">
              <Offset>
                <AbsDimension x="0" y="-15"/>
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>

        <!-- Database label -->
        <FontString name="$parentDbLabel" inherits="GameFontNormalSmall">
          <Anchors>
            <Anchor point="TOP">
              <Offset>
                <AbsDimension x="0" y="-30"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="0.7" g="0.7" b="0.7"/>
        </FontString>
      </Layer>
    </Layers>

    <Frames>
      <!-- Draggable title bar -->
      <Frame name="$parentTitleBar" enableMouse="true">
        <Size>
          <AbsDimension x="0" y="20"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="10" y="-10"/>
            </Offset>
          </Anchor>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-30" y="-10"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Frame>

      <!-- Close button -->
      <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-5" y="-5"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Button>

      <!-- Database-selector dropdown: 5px from each side border -->
      <!-- Frame width=235, 5px each side => 225px total. UIDropDownMenu total = SetWidth+25, so SetWidth=200 -->
      <Frame name="$parentDbDropdown" inherits="UIDropDownMenuTemplate">
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="7" y="-35"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Frame>

      <!-- Slots container -->
      <Frame name="$parentSlotsContainer">
        <Size>
          <AbsDimension x="200" y="200"/>
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="20" y="-62"/>
            </Offset>
          </Anchor>
        </Anchors>
      </Frame>
    </Frames>

    <Scripts>
      <OnLoad>
        this:SetBackdropColor(0, 0, 0, 1)
      </OnLoad>
    </Scripts>
  </Frame>

</Ui>
